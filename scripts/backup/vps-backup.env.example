# Copy this to /etc/vps-backup.env on the VPS, edit values, chmod 600.
#
# How to get values:
#   TG_TOKEN: open @BotFather → /newbot → follow prompts. Token looks like
#             123456789:AABBccDDeeFFggHHiiJJkkLL
#   TG_CHAT_ID: open @userinfobot in Telegram → /start. It replies with your
#               numeric user ID. That goes here.
#
# Don't forget to /start the new backup bot in Telegram once, otherwise it
# can't message you (Telegram API restriction).

TG_TOKEN=PUT_BOT_TOKEN_HERE
TG_CHAT_ID=PUT_YOUR_USER_ID_HERE
