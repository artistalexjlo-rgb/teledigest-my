[telegram]
# Can be overridden by env: TELEGRAM_API_ID, TELEGRAM_API_HASH, TELEGRAM_BOT_TOKEN
api_id = 0
api_hash = ""
bot_token = ""

[bot]
channels = ["https://t.me/+eiMhge42Ie00NDUy", "@Brazil_ChatForum"]
summary_target = "@Digest_Br"
summary_hour = 23
summary_minute = 30
time_zone = "Europe/Moscow"
allowed_users = "@alex_j_lo"
bot_name = "MOZG"

[llm]
# Can be overridden by env: DEEPSEEK_API_KEY
model = "deepseek-chat"
api_key = ""
base_url = "https://api.deepseek.com/v1"
temperature = 0.4

[llm.prompts]
system = """
Ты — редактор русскоязычного Telegram-канала о жизни и путешествиях в Бразилии.
Делай краткие, полезные дайджесты из сообщений чатов.
Пиши на русском, неформально но информативно.
Группируй по темам. В конце каждой темы добавляй хештеги.
Игнорируй рекламные сообщения, промо-ссылки, платные продукты и услуги от ботов и админов каналов. Не включай в дайджест ничего что продаёт: карты, курсы, обмен валют, услуги переводчиков. Только реальные вопросы и ответы живых людей.
Форматируй текст только тегами HTML для Telegram: <b>жирный</b>, <i>курсив</i>, <code>код</code>.
Никогда не используй Markdown (**, ###, ```, ---). Никаких заголовков с #.
"""

user = """
Сделай дайджест из следующих сообщений за {DAY}:

{MESSAGES}
"""

[storage]
db_path = "data/messages_fts.db"

[storage.rag]
keywords = [
    "виза", "CPF", "жильё", "аренда",
    "деньги", "карта", "симка", "такси",
    "безопасность", "страховка", "перелёт",
]

[[sources.channels]]
name = "TravelAsk Brazil"
url = "https://t.me/+eiMhge42Ie00NDUy"
country = "br"
language = "ru"

[[sources.channels]]
name = "Brazil Chat Forum"
url = "@Brazil_ChatForum"
country = "br"
language = "ru"

[sources.digest_targets]
br = "@Digest_Br"

# --- Gemini МОЗГ (optional override) ---
# API key читается из env GEMINI_API_KEY (см. Dokploy → Environment).
# Эта секция нужна ТОЛЬКО если хочешь переопределить имя модели.
# Имена preview-моделей у Google меняются ~раз в месяц — точный ID см.
# в https://aistudio.google.com (выпадашка моделей в playground).
#
# [gemini]
# live_model = "gemini-3.1-flash-live-preview"  # для МОЗГ-ответов через Live API
# model = "gemini-3.1-flash-lite-preview"       # sync fallback модель

[google]
# Drive: OAuth token — mint once with scripts/drive_oauth_init.py (Drive scopes only)
token_path = "/home/teledigest/data/google-token.json"
drive_folder_id = "16cEzGQy0ThTmTm_U3yoLi8uDURqHiFJf"
# Firestore: Service Account — never expires, no re-auth needed
service_account_path = "/home/teledigest/data/service-account.json"
firestore_project_id = "project-56cb62a9-8914-4ae3-b44"
firestore_database = "default"
