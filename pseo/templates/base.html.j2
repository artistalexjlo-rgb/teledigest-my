<!DOCTYPE html>
<html lang="{{ t.html_lang }}" data-theme="dark">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
{%- if site.draft or page.noindex %}
<meta name="robots" content="noindex, nofollow">
{%- endif %}
<title>{{ page.title }}</title>
<meta name="description" content="{{ page.meta_desc }}">
<link rel="canonical" href="{{ site.domain }}{{ page.path }}">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
{%- set tail = page.path.split('/')[2:] | join('/') %}
{%- for l in site.languages %}
<link rel="alternate" hreflang="{{ l }}" href="{{ site.domain }}/{{ l }}/{{ tail }}">
{%- endfor %}
<link rel="alternate" hreflang="x-default" href="{{ site.domain }}/{{ site.languages[0] }}/{{ tail }}">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;700;800&family=Orbitron:wght@600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#06080d; --card:#0f1620; --border:#21303f; --text:#e8f1f8; --muted:#6b8299;
  --hud:#3ad8ff; --hud-dim:rgba(58,216,255,0.42);
  --accent:#a78bfa; --green:#4ade80; --yellow:#fbbf24; --amber-edge:#f59e0b; --red:#f87171;
  --font-display:'Orbitron','JetBrains Mono',sans-serif;
  --font-mono:'JetBrains Mono',ui-monospace,Menlo,monospace;
  --font-body:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  --maxw:720px;
}
[data-theme="light"]{
  --bg:#eef2f6; --card:#ffffff; --border:#cfdae5; --text:#16212e; --muted:#5a6b7d;
  --hud:#0a87b8; --hud-dim:rgba(10,135,184,0.30);
  --accent:#6d4bd8; --green:#1f9d57; --yellow:#b9760a; --amber-edge:#b9760a;
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{margin:0;font-family:var(--font-body);font-weight:500;line-height:1.62;
  font-size:17px;color:var(--text);background-color:var(--bg);
  background-image:
    radial-gradient(120% 70% at 50% -8%,rgba(58,216,255,0.10),transparent 60%),
    radial-gradient(90% 60% at 100% 108%,rgba(124,58,237,0.08),transparent 60%),
    repeating-linear-gradient(62deg,transparent 0 46px,rgba(58,216,255,0.035) 46px 47px,transparent 47px 92px),
    repeating-linear-gradient(-62deg,transparent 0 60px,rgba(124,58,237,0.03) 60px 61px,transparent 61px 122px),
    linear-gradient(180deg,#080b12,#05070b);
  background-attachment:fixed;}
[data-theme="light"] body{background-image:
    radial-gradient(120% 70% at 50% -8%,rgba(10,135,184,0.06),transparent 60%),
    linear-gradient(180deg,#eef2f6,#e7edf3);}
.wrap{max-width:var(--maxw);margin:0 auto;padding:18px 18px 80px}
a{color:var(--hud);text-decoration:none}
a:hover{text-decoration:underline}

/* ── SVG-октагон (ДС even-cant): один path fill+stroke, non-scaling-stroke, скруглён.
   Форма перерисовывается JS под реальный размер (см. скрипт внизу). overflow:visible
   ОБЯЗАТЕЛЕН — иначе SVG срежет внешнюю половину канта. ── */
.oct{position:absolute;inset:0;width:100%;height:100%;z-index:-1;pointer-events:none;display:block;overflow:visible}
.oct path{vector-effect:non-scaling-stroke;stroke-width:1.4;stroke-linejoin:round;fill:#0d1822;stroke:var(--hud-dim)}
[data-theme="light"] .oct path{fill:#fff}

.top{display:flex;align-items:flex-start;justify-content:space-between;padding:10px 0 18px}
.brand{display:flex;flex-direction:column;align-items:flex-start;gap:7px}
.brand-row{display:flex;align-items:center;gap:12px}
.brand .coin{width:42px;height:42px;flex:none;display:grid;place-items:center;border-radius:8px;
  background:radial-gradient(120% 120% at 30% 25%,#2bb6f2,#0a4f8c 70%,#063256);color:#fff;
  font-size:1.05rem;font-weight:800;box-shadow:0 0 14px rgba(58,216,255,.45),inset 0 1px 2px rgba(255,255,255,.4)}
.lk-name{font-family:var(--font-display);font-weight:800;font-size:1.55rem;letter-spacing:.01em}
.lk-name b{color:var(--hud);text-shadow:0 0 12px var(--hud-dim)}
.brand-sub{font-family:var(--font-mono);font-weight:700;font-size:.58rem;
  letter-spacing:.16em;text-transform:uppercase;color:var(--muted)}
.brand-sub i{color:var(--hud);font-style:normal;opacity:.85}
.toggle{position:relative;isolation:isolate;font-family:var(--font-mono);font-weight:700;font-size:.72rem;
  letter-spacing:.12em;text-transform:uppercase;color:var(--text);cursor:pointer;padding:8px 14px;
  background:transparent;border:none}
.toggle .oct path{fill:var(--card);stroke:var(--border)}
.toggle:hover{color:var(--hud)} .toggle:hover .oct path{stroke:var(--hud)}
.crumbs{font-family:var(--font-mono);font-size:.72rem;letter-spacing:.08em;color:var(--muted);
  text-transform:uppercase;margin-bottom:14px}
.crumbs a{color:var(--muted)} .crumbs b{color:var(--hud)}
h1{font-family:var(--font-display);font-weight:800;font-size:1.9rem;line-height:1.15;
  letter-spacing:.01em;margin:.2em 0 .4em;text-transform:uppercase}
h2{font-family:var(--font-display);font-weight:700;font-size:1.15rem;letter-spacing:.05em;
  text-transform:uppercase;margin:2.2em 0 .7em;color:var(--text)}
.section-label{font-family:var(--font-mono);font-size:.66rem;letter-spacing:.18em;
  text-transform:uppercase;color:var(--hud);margin-bottom:6px;display:block}
.prose{font-size:1.02rem;line-height:1.7;margin:8px 0 4px}
.prose p{margin:0 0 1em} .prose strong{color:var(--hud)}

.plate{position:relative;isolation:isolate;margin:16px 0}
.plate .pad{padding:18px 20px;position:relative}
.answer .pad{font-size:1.05rem;line-height:1.6}
.answer strong{color:var(--hud)}
.num{font-family:var(--font-mono);font-weight:700;color:var(--hud)}
details{border-bottom:1px solid var(--border);padding:14px 2px}
details summary{cursor:pointer;font-weight:700;font-size:1.02rem;list-style:none;
  display:flex;justify-content:space-between;gap:12px}
details summary::-webkit-details-marker{display:none}
details summary::after{content:'+';font-family:var(--font-mono);color:var(--hud);font-size:1.2rem}
details[open] summary::after{content:'\2212'}
details .a{padding-top:10px;color:var(--text);opacity:.92}
details .src{font-family:var(--font-mono);font-size:.66rem;letter-spacing:.06em;
  color:var(--muted);text-transform:uppercase;margin-top:8px}
.chips{display:flex;flex-wrap:wrap;gap:10px;margin:8px 0}
.chip{position:relative;isolation:isolate;font-family:var(--font-mono);font-size:.74rem;letter-spacing:.06em;
  text-transform:uppercase;padding:10px 16px;color:var(--text);background:transparent}
.chip:hover{color:var(--hud);text-decoration:none} .chip:hover .oct path{stroke:var(--hud)}
.chip.soon{color:var(--muted);cursor:default;pointer-events:none}
.chip.soon::after{content:'· скоро';opacity:.7;margin-left:6px}
.qlist{list-style:none;padding:0;margin:10px 0}
.qlist li{padding:14px 2px 14px 28px;border-bottom:1px solid var(--border);font-size:1.04rem;
  font-weight:600;position:relative}
.qlist li::before{content:'«';position:absolute;left:2px;top:11px;color:var(--hud);font-size:1.3rem}

/* ── Хаб-сетка (index): карточки-октагоны ── */
.grid{display:flex;flex-wrap:wrap;gap:14px;margin:18px 0}
.card{position:relative;isolation:isolate;display:block;width:calc(50% - 7px);min-width:230px;flex:1 1 230px;
  padding:18px 20px;color:var(--text)}
.card .oct path{fill:var(--card);stroke:var(--hud-dim)}
.card:hover{text-decoration:none} .card:hover .oct path{stroke:var(--hud)}
.card .ti{font-family:var(--font-display);font-weight:700;font-size:1.05rem;letter-spacing:.02em;
  text-transform:uppercase;display:flex;align-items:center;gap:10px}
.card .ds{display:block;font-size:.9rem;color:var(--muted);margin-top:6px;text-transform:none;letter-spacing:0}
.card.soon{cursor:default;pointer-events:none}
.card.soon .ti{color:var(--muted)}
.card.soon .ti::after{content:'· скоро';font-family:var(--font-mono);font-size:.6rem;opacity:.7}

.cta{margin-top:34px}
.cta .oct path{fill:#160c02;stroke:var(--amber-edge)}
[data-theme="light"] .cta .oct path{fill:#fdf1d8}
.cta .pad{display:flex;flex-direction:column;gap:12px;align-items:flex-start}
.cta h2{margin:0;color:var(--yellow);text-shadow:0 0 14px rgba(245,158,11,.4)}
.cta p{margin:0;color:var(--text);opacity:.9}
.cta .ps{opacity:.66;font-size:.92rem;font-style:italic}
.cta .btn{position:relative;isolation:isolate;font-family:var(--font-body);font-weight:800;font-size:1rem;
  letter-spacing:.02em;text-transform:uppercase;color:#ffe8c2;background:transparent;padding:15px 24px;
  border:none;cursor:pointer;text-decoration:none;display:inline-block;
  text-shadow:0 0 12px rgba(245,158,11,.7);filter:drop-shadow(0 0 7px rgba(245,158,11,.4));transition:transform .1s}
.cta .btn .oct path{fill:#160c02;stroke:var(--amber-edge)}
[data-theme="light"] .cta .btn .oct path{fill:#fff3df}
.cta .btn:hover{transform:scale(.98);text-decoration:none}
footer{margin-top:46px;padding-top:18px;border-top:1px solid var(--border);color:var(--muted)}
.f-brand{font-family:var(--font-display);font-weight:800;font-size:.95rem;letter-spacing:.02em;color:var(--text)}
.f-brand b{color:var(--hud)}
.f-links{display:flex;flex-wrap:wrap;gap:18px;margin:12px 0}
.f-links a{font-family:var(--font-mono);font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
.f-links a:hover{color:var(--hud)}
.f-disc{font-size:.82rem;line-height:1.5;max-width:560px;margin:10px 0}
.f-copy{font-family:var(--font-mono);font-size:.66rem;letter-spacing:.08em;text-transform:uppercase;margin-top:10px}
</style>
</head>
{#- октагоны = SVG fill+stroke, БЕЗ clip-path. viewBox/path в макросе — ФОЛБЭК до JS;
    реальная форма перерисовывается под размер коробки скриптом внизу (data-cant/round). #}
{%- set OCT_TOGGLE = ["0 0 80 34", "M4.59,1.41Q6.00,0.00 8.00,0.00L72.00,0.00Q74.00,0.00 75.41,1.41L78.59,4.59Q80.00,6.00 80.00,8.00L80.00,26.00Q80.00,28.00 78.59,29.41L75.41,32.59Q74.00,34.00 72.00,34.00L8.00,34.00Q6.00,34.00 4.59,32.59L1.41,29.41Q0.00,28.00 0.00,26.00L0.00,8.00Q0.00,6.00 1.41,4.59Z"] %}
{%- set OCT_CHIP = ["0 0 150 37", "M5.88,2.12Q8.00,0.00 11.00,0.00L139.00,0.00Q142.00,0.00 144.12,2.12L147.88,5.88Q150.00,8.00 150.00,11.00L150.00,26.00Q150.00,29.00 147.88,31.12L144.12,34.88Q142.00,37.00 139.00,37.00L11.00,37.00Q8.00,37.00 5.88,34.88L2.12,31.12Q0.00,29.00 0.00,26.00L0.00,11.00Q0.00,8.00 2.12,5.88Z"] %}
{%- set OCT_BTN = ["0 0 203 56", "M5.88,2.12Q8.00,0.00 11.00,0.00L192.00,0.00Q195.00,0.00 197.12,2.12L200.88,5.88Q203.00,8.00 203.00,11.00L203.00,45.00Q203.00,48.00 200.88,50.12L197.12,53.88Q195.00,56.00 192.00,56.00L11.00,56.00Q8.00,56.00 5.88,53.88L2.12,50.12Q0.00,48.00 0.00,45.00L0.00,11.00Q0.00,8.00 2.12,5.88Z"] %}
{%- set OCT_BOX = ["0 0 680 185", "M9.88,2.12Q12.00,0.00 15.00,0.00L665.00,0.00Q668.00,0.00 670.12,2.12L677.88,9.88Q680.00,12.00 680.00,15.00L680.00,170.00Q680.00,173.00 677.88,175.12L670.12,182.88Q668.00,185.00 665.00,185.00L15.00,185.00Q12.00,185.00 9.88,182.88L2.12,175.12Q0.00,173.00 0.00,170.00L0.00,15.00Q0.00,12.00 2.12,9.88Z"] %}
{%- macro oct(o, cant, round) %}<svg class="oct" data-cant="{{ cant }}" data-round="{{ round }}" viewBox="{{ o[0] }}" preserveAspectRatio="none" aria-hidden="true"><path d="{{ o[1] }}"/></svg>{% endmacro %}
<body class="luky-surface">
<div class="wrap">

  <div class="top">
    <div class="brand">
      <span class="brand-row">
        <span class="coin">A文</span>
        <span class="lk-name">Lu<b>ky</b></span>
      </span>
      <span class="brand-sub">{{ t.brand_sub | safe }}</span>
    </div>
    <button class="toggle" id="themeBtn" aria-label="theme">{{ oct(OCT_TOGGLE, 6, 2) }}<span id="themeLbl">{{ t.theme_night }}</span></button>
  </div>

  {% block crumbs %}{% endblock %}

  {% block content %}{% endblock %}

  <footer>
    <div class="f-brand">Lu<b>ky</b> {{ t.footer_brand_tail }}</div>
    <nav class="f-links">
      <a href="/{{ t.html_lang }}/about/">{{ t.nav_about }}</a>
      {%- if page.geo %}
      <a href="/{{ t.html_lang }}/{{ page.geo }}/">{{ t.nav_topics }}</a>
      {%- endif %}
      <a href="/{{ t.html_lang }}/">{{ t.nav_countries }}</a>
      <a href="{{ site.telegram_url }}" target="_blank" rel="noopener">{{ t.nav_telegram }}</a>
    </nav>
    <p class="f-disc">{{ t.footer_disclaimer }}</p>
    <div class="f-copy">© {{ site.year }} {{ site.brand }} · {{ t.footer_updated }} {{ page.updated }}</div>
  </footer>

</div>

{% block jsonld %}{% endblock %}

<script>
(function(){
  var root=document.documentElement, btn=document.getElementById('themeBtn'), lbl=document.getElementById('themeLbl');
  var NIGHT={{ t.theme_night | tojson }}, DAY={{ t.theme_day | tojson }};
  function get(){try{return localStorage.getItem('ms-theme');}catch(e){return null;}}
  function set(v){try{localStorage.setItem('ms-theme',v);}catch(e){}}
  var saved=get(); if(saved){root.setAttribute('data-theme',saved);}
  function label(){lbl.textContent = root.getAttribute('data-theme')==='light' ? DAY : NIGHT;}
  label();
  btn.addEventListener('click',function(){
    var next = root.getAttribute('data-theme')==='light' ? 'dark' : 'light';
    root.setAttribute('data-theme',next); set(next); label();
  });
})();
</script>

<script>
/* Октагон: рисуем path под РЕАЛЬНЫЙ размер коробки (не растягиваем готовый контур).
   Скос фикс-px + скругление строятся в настоящих px → ровный 45° на любом размере.
   ResizeObserver ловит изменение размера от чего угодно (контент, перенос, шрифт). */
(function(){
  function pts(w,h,c){return[[c,0],[w-c,0],[w,c],[w,h-c],[w-c,h],[c,h],[0,h-c],[0,c]];}
  function rp(p,r){var n=p.length,d="";function u(a,b){var dx=b[0]-a[0],dy=b[1]-a[1],L=Math.hypot(dx,dy)||1;return[dx/L,dy/L];}
    for(var i=0;i<n;i++){var p1=p[i],p0=p[(i-1+n)%n],p2=p[(i+1)%n],u0=u(p1,p0),u2=u(p1,p2),
      l0=Math.hypot(p0[0]-p1[0],p0[1]-p1[1]),l2=Math.hypot(p2[0]-p1[0],p2[1]-p1[1]),rr=Math.min(r,l0/2,l2/2),
      a=[p1[0]+u0[0]*rr,p1[1]+u0[1]*rr],b=[p1[0]+u2[0]*rr,p1[1]+u2[1]*rr];
      d+=(i?"L":"M")+a[0].toFixed(2)+","+a[1].toFixed(2)+"Q"+p1[0].toFixed(2)+","+p1[1].toFixed(2)+" "+b[0].toFixed(2)+","+b[1].toFixed(2);}
    return d+"Z";}
  function draw(svg){var w=Math.round(svg.clientWidth),h=Math.round(svg.clientHeight);if(w<4||h<4)return;
    var c=Math.min(parseFloat(svg.dataset.cant)||8,w/2-1,h/2-1),r=parseFloat(svg.dataset.round);if(isNaN(r))r=3;
    svg.setAttribute("viewBox","0 0 "+w+" "+h);svg.firstElementChild.setAttribute("d",rp(pts(w,h,c),r));}
  var ro=window.ResizeObserver?new ResizeObserver(function(es){for(var i=0;i<es.length;i++)draw(es[i].target);}):null;
  function init(){var l=document.querySelectorAll("svg.oct");for(var i=0;i<l.length;i++){draw(l[i]);if(ro)ro.observe(l[i]);}}
  if(document.readyState!=="loading")init();else document.addEventListener("DOMContentLoaded",init);
  if(!ro){window.addEventListener("load",init);var t;window.addEventListener("resize",function(){clearTimeout(t);t=setTimeout(init,120);});}
})();
</script>
{% block scripts %}{% endblock %}
</body>
</html>
